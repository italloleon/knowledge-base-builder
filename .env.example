# ============================================================
# Knowledge Base Builder — Environment Variables Reference
# Copy this file to .env and fill in ALL values marked CHANGE_ME.
# Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# PostgreSQL connection string (asyncpg driver)
# Must match POSTGRES_USER / POSTGRES_PASSWORD below.
# ----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://kbb:CHANGE_ME_DB_PASSWORD@postgres:5432/kbb

# ----------------------------------------------------------
# Redis connection string — include password if set
# Format: redis://:<password>@<host>:<port>/<db>
# ----------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ----------------------------------------------------------
# Directory on disk where uploaded PDF files are stored
# ----------------------------------------------------------
UPLOAD_DIR=/app/uploads

# ----------------------------------------------------------
# Maximum allowed upload size in megabytes
# ----------------------------------------------------------
MAX_UPLOAD_SIZE_MB=50

# ----------------------------------------------------------
# Authentication — MUST be true in production
# Generate JWT_SECRET_KEY with: openssl rand -hex 32
# ----------------------------------------------------------
AUTH_ENABLED=true
JWT_SECRET_KEY=CHANGE_ME_RUN_openssl_rand_-hex_32

# ----------------------------------------------------------
# Comma-separated list of allowed CORS origins
# Example: http://1.2.3.4:8080
# ----------------------------------------------------------
ALLOWED_ORIGINS=CHANGE_ME_http://YOUR_VPS_IP:8080

# ----------------------------------------------------------
# Application log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ----------------------------------------------------------
LOG_LEVEL=INFO

# ----------------------------------------------------------
# LLM enrichment provider: "ollama" | "gemini"
# ----------------------------------------------------------
ENRICHMENT_PROVIDER=ollama

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_ENRICHMENT_CONCURRENCY=1
OLLAMA_TIMEOUT_SECONDS=120

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENRICHMENT_CONCURRENCY=5
GEMINI_TIMEOUT_SECONDS=30

# ----------------------------------------------------------
# Port exposed on the host for the web UI
# ----------------------------------------------------------
APP_PORT=8080

# ----------------------------------------------------------
# PostgreSQL service credentials (consumed by the postgres container)
# Must match DATABASE_URL above.
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------
POSTGRES_DB=kbb
POSTGRES_USER=kbb
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ----------------------------------------------------------
# Redis password (consumed by the redis container)
# Must match REDIS_URL above.
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
