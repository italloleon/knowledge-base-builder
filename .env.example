# ============================================================
# Knowledge Base Builder — Environment Variables Reference
# Copy this file to .env and fill in real values.
# ============================================================

# ----------------------------------------------------------
# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
# Required: yes
# ----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://kbb:kbbpassword@postgres:5432/kbb

# ----------------------------------------------------------
# Redis connection string
# Format: redis://<host>:<port>/<db>
# Required: yes
# ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------
# Directory on disk where uploaded PDF files are stored
# The container mounts a named volume at this path.
# Default: /app/uploads
# ----------------------------------------------------------
UPLOAD_DIR=/app/uploads

# ----------------------------------------------------------
# Maximum allowed upload size in megabytes
# Files larger than this will be rejected with HTTP 413.
# Default: 50
# ----------------------------------------------------------
MAX_UPLOAD_SIZE_MB=50

# ----------------------------------------------------------
# Enable API key authentication
# Set to true to require X-API-Key header on all non-health endpoints.
# Default: false (authentication disabled — all requests pass through)
# ----------------------------------------------------------
AUTH_ENABLED=false

# ----------------------------------------------------------
# API key value (only checked when AUTH_ENABLED=true)
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------
API_KEY=

# ----------------------------------------------------------
# Application log level
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# ----------------------------------------------------------
LOG_LEVEL=INFO

# ----------------------------------------------------------
# PostgreSQL service configuration (used by docker-compose)
# These are consumed by the postgres service, not the app.
# ----------------------------------------------------------
POSTGRES_DB=kbb
POSTGRES_USER=kbb
POSTGRES_PASSWORD=kbbpassword
